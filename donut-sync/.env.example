PORT=3929

S3_ENDPOINT=http://localhost:8987
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET=donut-sync

# Self-hosted mode: set a shared token instead of JWT-based hosted auth.
SYNC_TOKEN=

# Hosted mode: donut-sync validates RS256 JWTs issued by the Supabase Edge Function.
SYNC_JWT_PUBLIC_KEY=

# Hosted usage/account reporting.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public hosted example using Cloudflare R2 + Railway:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=<r2-access-key-id>
# S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
# S3_FORCE_PATH_STYLE=false
# S3_BUCKET=twitterbrowser-sync
